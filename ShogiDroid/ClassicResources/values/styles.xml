<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="AppTheme" parent="Theme.AppCompat.DayNight">
        <item name="android:fontFamily">@font/hirakaku</item>
        <item name="fontFamily">@font/hirakaku</item>
        <item name="android:windowBackground">@color/theme_background</item>
        <item name="colorPrimary">@color/title_background</item>
        <item name="colorPrimaryDark">@color/theme_background</item>
        <item name="android:statusBarColor">@color/theme_background</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <style name="AppTheme.SurfaceTitle">
        <item name="android:textColor">@color/primary_text</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="AppTheme.SurfaceBody">
        <item name="android:textColor">@color/secondary_text</item>
    </style>

    <style name="AppTheme.FilledButton">
        <item name="android:textColor">@color/title_text</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="AppTheme.OutlinedButton">
        <item name="android:textColor">@color/primary_text</item>
    </style>

    <style name="AppTheme.PlayerChip">
        <item name="android:textColor">@color/primary_text</item>
    </style>
</resources>
