<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen
  xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">
    <PreferenceCategory android:title="@string/SettingsTimeControl_Text">
        <shogidroid.controls.ListIntPreference android:entries="@array/SettingsTime_Texts" android:title="@string/SettingsTime_Text" android:key="Engine.Time" android:defaultValue="@string/SettingsTime_Default" android:entryValues="@array/SettingsTime_Values" />
        <shogidroid.controls.ListIntPreference android:entries="@array/SettingsCountdown_Texts" android:title="@string/SettingsCountdown_Text" android:key="Engine.Countdown" android:defaultValue="@string/SettingsCountdown_Default" android:entryValues="@array/SettingsCountdown_Values" />
    </PreferenceCategory>
    <PreferenceCategory android:title="@string/SettingsEngineSettings_Text">
        <shogidroid.controls.SeekBarPreference android:title="@string/SettingsEngineStrength_Text" android:key="Engine.Strength" app:SeekBarMax="100" android:defaultValue="100" />
        <CheckBoxPreference android:title="@string/SettingsEnginePondering_Text" android:key="Engine.Ponder" android:defaultValue="false" />
        <shogidroid.controls.ListIntPreference android:entries="@array/SettingsHashTable_Texts" android:title="@string/SettingsEngineHashTable_Text" android:key="Engine.HashSize" android:defaultValue="@string/SettingsHashTable_Default" android:entryValues="@array/SettingsHashTable_Values" />
        <CheckBoxPreference android:title="@string/SettingsEngineOwnBook_Text" android:key="Engine.OwnBook" android:defaultValue="true" />
    </PreferenceCategory>
    <PreferenceCategory android:title="@string/SettingsAnalyze_Text">
        <shogidroid.controls.ListIntPreference android:entries="@array/SettingsAnalyzeTime_Texts" android:title="@string/SettingsAnalyzeTime_Text" android:key="Analyze.Time" android:defaultValue="@string/SettingsAnalyzeTime_Default" android:entryValues="@array/SettingsAnalyzeTime_Values" />
        <shogidroid.controls.ListIntPreference android:entries="@array/SettingsAnalyzeMultiPv_Texts" android:title="@string/SettingsAnalyzeMultiPv_Text" android:key="Analyze.MultiPv" android:defaultValue="@string/SettingsAnalyzeMultiPv_Default" android:entryValues="@array/SettingsAnalyzeMultiPv_Values" />
        <CheckBoxPreference android:title="@string/SettingsEngineOwnBook_Text" android:key="Analyze.OwnBook" android:defaultValue="true" />
    </PreferenceCategory>
    <PreferenceCategory android:title="@string/SettingsAppearance_Text">
        <CheckBoxPreference android:title="@string/SettingsShowHintArrow_Text" android:key="App.ShowHintArrow" android:defaultValue="true" />
        <CheckBoxPreference android:title="@string/SettingsShowNextMoveArrow_Text" android:key="App.ShowNextArrow" android:defaultValue="true" />
        <CheckBoxPreference android:title="@string/SettingsShowComputerThinking_Text" android:key="App.ShowComputerThinking" android:defaultValue="true" />
        <ListPreference android:entries="@array/SettingsAnimateSpeed_Texts" android:title="@string/SettingsAnimateMoves_Text" android:key="App.AnimationSpeed" android:defaultValue="@string/SettingsAnimateSpeed_Default" android:entryValues="@array/SettingsAnimateSpeed_Values" />
        <ListPreference android:entries="@array/SettingsMoveStyle_Texts" android:title="@string/SettingsMoveStyle_Text" android:key="App.MoveStyle" android:defaultValue="@string/SettingsMoveStyle_Default" android:entryValues="@array/SettingsMoveStyle_Values" />
        <shogidroid.controls.ListIntPreference android:entries="@array/SettingsPlayInterval_Texts" android:title="@string/SettingsPlayInterval_Text" android:key="App.PlayInterval" android:entryValues="@array/SettingsPlayInterval_Values" />
        <CheckBoxPreference android:title="@string/SettingsDispToolbar_Text" android:key="App.DispToolbar" android:defaultValue="false" />
        <shogidroid.controls.ListIntPreference android:entries="@array/SettingsPVDisplay_Texts" android:title="@string/SettingsPVDisplay_Text" android:key="App.PVDisplay" android:entryValues="@array/SettingsPVDisplay_Values" />
        <CheckBoxPreference android:title="@string/SettingsEvalGraphLiner_Text" android:key="App.GraphLiner" android:defaultValue="true" />
    </PreferenceCategory>
    <PreferenceCategory android:title="@string/SettingsOther_Text">
        <EditTextPreference android:singleLine="true" android:title="@string/SettingsPlayerName_Text" android:key="App.PlayerName" android:defaultValue="Player" />
        <EditTextPreference android:singleLine="true" android:title="@string/SettingsShogiWarsUserName_Text" android:key="App.WarsUserName" android:defaultValue="" />
        <CheckBoxPreference android:title="@string/SettingsAutoSave_Text" android:key="App.AutoSave" android:defaultValue="true" />
        <CheckBoxPreference android:title="@string/SettingsEnablePieceSounds_Text" android:key="App.PlaySE" android:defaultValue="true" />
    </PreferenceCategory>
    <PreferenceCategory android:title="@string/SettingsCustom_Text">
        <shogidroid.controls.ListIntPreference android:entries="@array/SettingsShortcutMenu_Texts" android:title="@string/SettingsReversButton_Text" android:key="App.ReverseButotn" android:entryValues="@array/SettingsShortcutMenu_Values" />
        <shogidroid.controls.ListIntPreference android:entries="@array/SettingsMenuButton_Texts" android:title="@string/SettingsMenuButton_Text" android:key="App.CustomMenuButton" android:entryValues="@array/SettingsMenuButton_Values" />
        <shogidroid.controls.ListIntPreference android:entries="@array/SettingsShortcutMenu_Texts" android:title="@string/SettingsShortcutMenu1_Text" android:key="App.ShortcutMenu1" android:entryValues="@array/SettingsShortcutMenu_Values" />
        <shogidroid.controls.ListIntPreference android:entries="@array/SettingsShortcutMenu_Texts" android:title="@string/SettingsShortcutMenu2_Text" android:key="App.ShortcutMenu2" android:entryValues="@array/SettingsShortcutMenu_Values" />
        <shogidroid.controls.ListIntPreference android:entries="@array/SettingsShortcutMenu_Texts" android:title="@string/SettingsShortcutMenu3_Text" android:key="App.ShortcutMenu3" android:entryValues="@array/SettingsShortcutMenu_Values" />
        <shogidroid.controls.ListIntPreference android:entries="@array/SettingsShortcutMenu_Texts" android:title="@string/SettingsShortcutMenu4_Text" android:key="App.ShortcutMenu4" android:entryValues="@array/SettingsShortcutMenu_Values" />
        <shogidroid.controls.ListIntPreference android:entries="@array/SettingsShortcutMenu_Texts" android:title="@string/SettingsShortcutMenu5_Text" android:key="App.ShortcutMenu5" android:entryValues="@array/SettingsShortcutMenu_Values" />
        <shogidroid.controls.ListIntPreference android:entries="@array/SettingsShortcutMenu_Texts" android:title="@string/SettingsShortcutMenu6_Text" android:key="App.ShortcutMenu6" android:entryValues="@array/SettingsShortcutMenu_Values" />
    </PreferenceCategory>
</PreferenceScreen>
