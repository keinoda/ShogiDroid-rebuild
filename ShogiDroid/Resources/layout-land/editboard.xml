<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    android:background="@drawable/window_background"
    android:orientation="horizontal"
    android:padding="12dp"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <FrameLayout
        android:layout_width="0dp"
        android:layout_height="fill_parent"
        android:layout_marginEnd="10dp"
        android:layout_weight="1"
        android:background="@drawable/board_frame_bg"
        android:elevation="6dp"
        android:padding="8dp">
        <shogidroid.controls.shogiboard.ShogiBoard android:id="@id/shogiboard" android:background="@color/theme_background" android:layout_width="fill_parent" android:layout_height="fill_parent" app:shogiBoardMode="Edit" />
    </FrameLayout>
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="fill_parent"
        android:layout_weight="1"
        android:orientation="vertical">
        <ImageButton android:id="@id/reverse_button" android:layout_width="44dp" android:layout_height="44dp" android:background="@drawable/icon_button_bg" android:contentDescription="@string/MenuReverse_Text" android:padding="10dp" android:src="@android:drawable/ic_menu_rotate" android:tint="@color/icon_tint" />
        <LinearLayout android:layout_width="fill_parent" android:layout_height="0dp" android:layout_weight="1" />
        <LinearLayout
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/surface_panel_bg"
            android:elevation="4dp"
            android:orientation="vertical"
            android:padding="14dp">
            <TextView android:layout_width="fill_parent" android:layout_height="wrap_content" android:text="@string/EditBoardInitialPosition_Text" android:textColor="@color/primary_text" android:textSize="16sp" android:textStyle="bold" />
            <LinearLayout android:layout_width="fill_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:orientation="horizontal">
                <Button android:id="@id/EditBoardEvenButton" style="@style/AppTheme.OutlinedButton" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginEnd="6dp" android:layout_weight="1" android:text="@string/EditBoardEvenButton_Text" />
                <Button android:id="@id/EditBoardMateButton" style="@style/AppTheme.OutlinedButton" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="6dp" android:layout_weight="1" android:text="@string/EditBoardMateButton_Text" />
            </LinearLayout>
            <LinearLayout android:layout_width="fill_parent" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:orientation="horizontal">
                <Button android:id="@id/EditBoardMirrorButton" style="@style/AppTheme.OutlinedButton" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginEnd="6dp" android:layout_weight="1" android:text="@string/EditBoardMirrorButton_Text" />
                <Button android:id="@id/EditBoardChangeTurnButton" style="@style/AppTheme.OutlinedButton" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="6dp" android:layout_weight="1" android:text="@string/EditBoardChangeTurnButton_Text" />
            </LinearLayout>
            <LinearLayout android:layout_width="fill_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:gravity="end" android:orientation="horizontal">
                <Button android:id="@id/CancelButton" style="@style/AppTheme.OutlinedButton" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/DialogCancel_Text" />
                <Button android:id="@id/OKButton" style="@style/AppTheme.FilledButton" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="10dp" android:text="@string/DialogOK_Text" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
