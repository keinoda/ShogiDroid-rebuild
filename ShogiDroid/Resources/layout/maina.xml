            <ImageButton android:id="@id/first_button" android:layout_width="0.0dip" android:layout_height="wrap_content" android:src="@android:drawable/ic_media_rew" android:layout_weight="0.7" />
            <ImageButton android:id="@id/prev_button" android:layout_width="0.0dip" android:layout_height="wrap_content" android:src="@android:drawable/ic_media_play" android:layout_weight="1.0" android:scaleX="-1.0" />
            <ImageButton android:id="@id/next_button" android:layout_width="0.0dip" android:layout_height="wrap_content" android:src="@android:drawable/ic_media_play" android:layout_weight="1.0" />
            <ImageButton android:id="@id/last_button" android:layout_width="0.0dip" android:layout_height="wrap_content" android:src="@android:drawable/ic_media_ff" android:layout_weight="0.7" />
            <View android:layout_width="0.0dip" android:layout_height="0.0dip" android:layout_weight="1.0" />
