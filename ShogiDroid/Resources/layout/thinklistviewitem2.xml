<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/surface_clickable_bg"
    android:minHeight="52dp"
    android:orientation="vertical"
    android:paddingLeft="12dp"
    android:paddingTop="10dp"
    android:paddingRight="12dp"
    android:paddingBottom="10dp"
    xmlns:android="http://schemas.android.com/apk/res/android">
    <LinearLayout android:orientation="horizontal" android:layout_width="fill_parent" android:layout_height="wrap_content" android:gravity="center_vertical">
        <TextView android:ellipsize="end" android:id="@id/depth" android:layout_width="wrap_content" android:layout_height="wrap_content" android:singleLine="true" android:textColor="@color/secondary_text" android:textSize="11sp" />
        <TextView android:ellipsize="end" android:gravity="center" android:id="@id/rank" android:layout_width="18dp" android:layout_height="wrap_content" android:layout_marginStart="8dp" android:singleLine="true" />
        <TextView android:ellipsize="end" android:id="@id/value" android:layout_width="60dp" android:layout_height="wrap_content" android:layout_marginStart="6dp" android:singleLine="true" android:textStyle="bold" />
        <TextView android:ellipsize="end" android:id="@id/moves" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="8dp" android:layout_weight="1" android:maxLines="1" />
    </LinearLayout>
</LinearLayout>
