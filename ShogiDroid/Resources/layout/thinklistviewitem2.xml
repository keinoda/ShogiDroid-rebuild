<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/surface_clickable_bg"
    android:gravity="center_vertical"
    android:minHeight="32dp"
    android:orientation="vertical"
    android:paddingLeft="6dp"
    android:paddingTop="2dp"
    android:paddingRight="6dp"
    android:paddingBottom="2dp"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <LinearLayout android:orientation="horizontal" android:layout_width="fill_parent" android:layout_height="wrap_content" android:gravity="center_vertical">
        <TextView android:ellipsize="end" android:id="@id/depth" android:layout_width="wrap_content" android:layout_height="wrap_content" android:includeFontPadding="false" android:singleLine="true" android:textColor="@color/secondary_text" android:textSize="10sp" />
        <TextView android:ellipsize="end" android:gravity="center" android:id="@id/rank" android:layout_width="16dp" android:layout_height="wrap_content" android:layout_marginStart="4dp" android:includeFontPadding="false" android:singleLine="true" />
        <TextView android:id="@id/value" android:layout_width="58dp" android:layout_height="wrap_content" android:layout_marginStart="3dp" android:gravity="center" android:includeFontPadding="false" android:singleLine="true" android:textSize="13sp" android:textStyle="bold" />
        <TextView android:ellipsize="end" android:id="@id/moves" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="4dp" android:layout_weight="1" android:includeFontPadding="false" android:maxLines="1" android:textSize="11sp" />
    </LinearLayout>
</LinearLayout>
